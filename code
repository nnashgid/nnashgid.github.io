<!DOCTYPE html>

<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>НАШ ГИД — Нижний Новгород</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=Geologica:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
–rust: #C4572A;
–gold: #D4A843;
–navy: #1A2744;
–cream: #F5EFE6;
–dark: #0F1A2E;
–mid: #2C3E5A;
–light-rust: #E8896B;
–text: #2A2015;
}

html { scroll-behavior: smooth; }

body {
font-family: ‘Geologica’, sans-serif;
background: var(–cream);
color: var(–text);
overflow-x: hidden;
}

/* NAV */
nav {
position: fixed;
top: 0; left: 0; right: 0;
z-index: 100;
display: flex;
align-items: center;
justify-content: space-between;
padding: 16px 40px;
background: rgba(15,26,46,0.92);
backdrop-filter: blur(12px);
border-bottom: 1px solid rgba(212,168,67,0.2);
}

.logo {
font-family: ‘Playfair Display’, serif;
font-size: 1.6rem;
font-weight: 900;
color: var(–cream);
letter-spacing: -0.02em;
text-decoration: none;
}
.logo span { color: var(–gold); }

.nav-links {
display: flex;
gap: 32px;
list-style: none;
}
.nav-links a {
color: rgba(245,239,230,0.75);
text-decoration: none;
font-size: 0.85rem;
font-weight: 500;
letter-spacing: 0.06em;
text-transform: uppercase;
transition: color 0.2s;
}
.nav-links a:hover { color: var(–gold); }

.nav-cta {
background: var(–rust);
color: var(–cream) !important;
padding: 8px 20px;
border-radius: 40px;
transition: background 0.2s !important;
}
.nav-cta:hover { background: var(–light-rust) !important; color: white !important; }

/* HERO */
.hero {
min-height: 100vh;
background: var(–dark);
position: relative;
display: flex;
align-items: flex-end;
overflow: hidden;
}

.hero-bg {
position: absolute;
inset: 0;
background:
radial-gradient(ellipse 80% 60% at 60% 40%, rgba(196,87,42,0.15) 0%, transparent 70%),
radial-gradient(ellipse 50% 80% at 20% 80%, rgba(212,168,67,0.1) 0%, transparent 60%),
linear-gradient(160deg, #0F1A2E 0%, #1A2744 50%, #0F1A2E 100%);
}

/* Animated geometric lines */
.hero-lines {
position: absolute;
inset: 0;
overflow: hidden;
}
.hero-lines::before {
content: ‘’;
position: absolute;
top: -10%;
right: 5%;
width: 1px;
height: 130%;
background: linear-gradient(to bottom, transparent, rgba(212,168,67,0.3), transparent);
animation: lineDrift 8s ease-in-out infinite alternate;
}
.hero-lines::after {
content: ‘’;
position: absolute;
top: 20%;
right: 15%;
width: 1px;
height: 60%;
background: linear-gradient(to bottom, transparent, rgba(196,87,42,0.4), transparent);
animation: lineDrift 12s ease-in-out infinite alternate-reverse;
}
@keyframes lineDrift {
from { transform: translateX(-20px) skewX(-2deg); opacity: 0.5; }
to { transform: translateX(20px) skewX(2deg); opacity: 1; }
}

.hero-kremlin {
position: absolute;
right: 0;
bottom: 0;
width: 55%;
height: 75%;
background: url(‘data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 500"><defs><linearGradient id="g" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="%231A2744" stop-opacity="0.4"/><stop offset="1" stop-color="%230F1A2E" stop-opacity="0.9"/></linearGradient></defs><rect fill="url(%23g)" width="800" height="500"/><g fill="%23253659" opacity="0.8"><!-- Tower 1 --><rect x="80" y="200" width="60" height="300"/><rect x="70" y="185" width="80" height="25"/><rect x="65" y="170" width="90" height="20"/><polygon points="110,120 75,170 145,170" fill="%231e4d7b" opacity="0.6"/><!-- Battlements --><rect x="68" y="160" width="10" height="15"/><rect x="83" y="160" width="10" height="15"/><rect x="98" y="160" width="10" height="15"/><rect x="113" y="160" width="10" height="15"/><rect x="128" y="160" width="10" height="15"/><rect x="143" y="160" width="10" height="15"/><!-- Wall --><rect x="140" y="250" width="200" height="250"/><rect x="140" y="235" width="200" height="20"/><!-- Battlements wall --><rect x="138" y="220" width="14" height="18"/><rect x="158" y="220" width="14" height="18"/><rect x="178" y="220" width="14" height="18"/><rect x="198" y="220" width="14" height="18"/><rect x="218" y="220" width="14" height="18"/><rect x="238" y="220" width="14" height="18"/><rect x="258" y="220" width="14" height="18"/><rect x="278" y="220" width="14" height="18"/><rect x="298" y="220" width="14" height="18"/><rect x="318" y="220" width="14" height="18"/><!-- Tower 2 --><rect x="340" y="160" width="70" height="340"/><rect x="328" y="145" width="94" height="25"/><polygon points="375,90 335,148 415,148" fill="%231e4d7b" opacity="0.6"/><!-- Battlements T2 --><rect x="326" y="130" width="12" height="18"/><rect x="344" y="130" width="12" height="18"/><rect x="362" y="130" width="12" height="18"/><rect x="380" y="130" width="12" height="18"/><rect x="398" y="130" width="12" height="18"/><rect x="416" y="130" width="12" height="18"/><!-- Wall 2 --><rect x="410" y="270" width="200" height="230"/><rect x="410" y="255" width="200" height="20"/><!-- Tower 3 --><rect x="610" y="220" width="55" height="280"/><rect x="600" y="205" width="75" height="22"/><polygon points="637,155 600,208 674,208" fill="%231e4d7b" opacity="0.6"/><!-- Battlements T3 --><rect x="598" y="190" width="11" height="16"/><rect x="614" y="190" width="11" height="16"/><rect x="630" y="190" width="11" height="16"/><rect x="646" y="190" width="11" height="16"/><rect x="662" y="190" width="11" height="16"/></g></svg>’) center/cover no-repeat;
opacity: 0.6;
}

.hero-content {
position: relative;
z-index: 2;
padding: 0 60px 80px;
max-width: 620px;
}

.hero-tag {
display: inline-block;
font-size: 0.7rem;
font-weight: 600;
letter-spacing: 0.18em;
text-transform: uppercase;
color: var(–gold);
border: 1px solid rgba(212,168,67,0.4);
padding: 5px 14px;
border-radius: 20px;
margin-bottom: 24px;
animation: fadeUp 0.8s ease both;
}

.hero h1 {
font-family: ‘Playfair Display’, serif;
font-size: clamp(3rem, 6vw, 5.5rem);
font-weight: 900;
color: var(–cream);
line-height: 1.0;
letter-spacing: -0.02em;
margin-bottom: 24px;
animation: fadeUp 0.8s ease 0.15s both;
}
.hero h1 em {
font-style: italic;
color: var(–gold);
}

.hero-desc {
font-size: 1rem;
color: rgba(245,239,230,0.65);
line-height: 1.7;
max-width: 440px;
margin-bottom: 40px;
animation: fadeUp 0.8s ease 0.3s both;
}

.hero-buttons {
display: flex;
gap: 14px;
flex-wrap: wrap;
animation: fadeUp 0.8s ease 0.45s both;
}

.btn-primary {
background: var(–rust);
color: white;
text-decoration: none;
padding: 14px 32px;
border-radius: 40px;
font-weight: 600;
font-size: 0.9rem;
letter-spacing: 0.04em;
transition: all 0.25s;
display: inline-flex;
align-items: center;
gap: 8px;
}
.btn-primary:hover {
background: var(–light-rust);
transform: translateY(-2px);
box-shadow: 0 12px 30px rgba(196,87,42,0.35);
}

.btn-outline {
background: transparent;
color: var(–cream);
text-decoration: none;
padding: 14px 32px;
border-radius: 40px;
font-weight: 500;
font-size: 0.9rem;
border: 1px solid rgba(245,239,230,0.25);
transition: all 0.25s;
}
.btn-outline:hover {
border-color: var(–gold);
color: var(–gold);
transform: translateY(-2px);
}

.hero-stats {
position: absolute;
right: 40px;
bottom: 80px;
z-index: 3;
display: flex;
flex-direction: column;
gap: 20px;
animation: fadeUp 0.8s ease 0.6s both;
}

.stat {
text-align: right;
}
.stat-num {
font-family: ‘Playfair Display’, serif;
font-size: 2.2rem;
font-weight: 900;
color: var(–cream);
line-height: 1;
}
.stat-num span { color: var(–gold); }
.stat-label {
font-size: 0.7rem;
letter-spacing: 0.1em;
text-transform: uppercase;
color: rgba(245,239,230,0.45);
}

@keyframes fadeUp {
from { opacity: 0; transform: translateY(24px); }
to { opacity: 1; transform: translateY(0); }
}

/* SEARCH BAR */
.search-section {
background: var(–navy);
padding: 28px 40px;
}
.search-bar {
max-width: 900px;
margin: 0 auto;
display: flex;
gap: 12px;
align-items: center;
}
.search-bar input {
flex: 1;
background: rgba(255,255,255,0.07);
border: 1px solid rgba(255,255,255,0.12);
color: white;
padding: 14px 20px;
border-radius: 10px;
font-family: inherit;
font-size: 0.95rem;
outline: none;
transition: border-color 0.2s;
}
.search-bar input::placeholder { color: rgba(255,255,255,0.35); }
.search-bar input:focus { border-color: var(–gold); }

.search-bar select {
background: rgba(255,255,255,0.07);
border: 1px solid rgba(255,255,255,0.12);
color: rgba(255,255,255,0.8);
padding: 14px 16px;
border-radius: 10px;
font-family: inherit;
font-size: 0.85rem;
outline: none;
cursor: pointer;
}
.search-bar button {
background: var(–rust);
color: white;
border: none;
padding: 14px 28px;
border-radius: 10px;
font-family: inherit;
font-weight: 600;
font-size: 0.9rem;
cursor: pointer;
transition: background 0.2s;
white-space: nowrap;
}
.search-bar button:hover { background: var(–light-rust); }

/* SECTION HEADERS */
.section-header {
display: flex;
align-items: flex-end;
justify-content: space-between;
margin-bottom: 40px;
}
.section-tag {
font-size: 0.68rem;
font-weight: 600;
letter-spacing: 0.18em;
text-transform: uppercase;
color: var(–rust);
display: block;
margin-bottom: 8px;
}
.section-title {
font-family: ‘Playfair Display’, serif;
font-size: clamp(1.8rem, 3vw, 2.8rem);
font-weight: 900;
color: var(–navy);
line-height: 1.1;
}
.section-link {
color: var(–rust);
text-decoration: none;
font-size: 0.85rem;
font-weight: 600;
letter-spacing: 0.04em;
display: flex;
align-items: center;
gap: 6px;
transition: gap 0.2s;
white-space: nowrap;
margin-bottom: 8px;
}
.section-link:hover { gap: 10px; }

/* MAP SECTION */
.map-section {
padding: 80px 40px;
background: var(–cream);
}

.map-wrapper {
display: grid;
grid-template-columns: 1fr 380px;
gap: 32px;
max-width: 1200px;
margin: 0 auto;
}

.map-container {
position: relative;
border-radius: 20px;
overflow: hidden;
background: #e8e4d8;
min-height: 520px;
box-shadow: 0 20px 60px rgba(26,39,68,0.12);
}

.map-placeholder {
width: 100%;
height: 100%;
min-height: 520px;
background: linear-gradient(135deg, #ddd8cc 0%, #c8c2b4 100%);
display: flex;
flex-direction: column;
align-items: center;
justify-content: center;
position: relative;
overflow: hidden;
}

/* SVG Map of NN */
.map-svg {
width: 100%;
height: 100%;
position: absolute;
inset: 0;
}

.map-overlay-label {
position: absolute;
bottom: 20px;
left: 20px;
background: white;
padding: 12px 18px;
border-radius: 12px;
box-shadow: 0 4px 20px rgba(0,0,0,0.1);
font-size: 0.8rem;
color: var(–text);
font-weight: 500;
display: flex;
align-items: center;
gap: 8px;
}
.map-overlay-label::before {
content: ‘📍’;
}

.map-pins {
position: absolute;
inset: 0;
}

.pin {
position: absolute;
cursor: pointer;
}
.pin-dot {
width: 14px;
height: 14px;
background: var(–rust);
border: 2px solid white;
border-radius: 50%;
box-shadow: 0 2px 8px rgba(196,87,42,0.5);
transition: transform 0.2s;
}
.pin:hover .pin-dot { transform: scale(1.4); }
.pin-label {
position: absolute;
bottom: 18px;
left: 50%;
transform: translateX(-50%);
background: var(–dark);
color: white;
padding: 4px 10px;
border-radius: 6px;
font-size: 0.7rem;
white-space: nowrap;
opacity: 0;
transition: opacity 0.2s;
pointer-events: none;
}
.pin:hover .pin-label { opacity: 1; }

.map-sidebar {
display: flex;
flex-direction: column;
gap: 14px;
}

.map-filter {
background: var(–navy);
border-radius: 16px;
padding: 20px;
}
.map-filter h3 {
color: var(–gold);
font-family: ‘Playfair Display’, serif;
font-size: 1rem;
margin-bottom: 14px;
}
.filter-chips {
display: flex;
flex-wrap: wrap;
gap: 8px;
}
.chip {
background: rgba(255,255,255,0.08);
border: 1px solid rgba(255,255,255,0.12);
color: rgba(245,239,230,0.8);
padding: 6px 14px;
border-radius: 20px;
font-size: 0.75rem;
cursor: pointer;
transition: all 0.2s;
font-family: inherit;
}
.chip:hover, .chip.active {
background: var(–rust);
border-color: var(–rust);
color: white;
}

.map-place-cards {
flex: 1;
overflow-y: auto;
display: flex;
flex-direction: column;
gap: 10px;
max-height: 380px;
padding-right: 4px;
}
.map-place-cards::-webkit-scrollbar { width: 3px; }
.map-place-cards::-webkit-scrollbar-track { background: transparent; }
.map-place-cards::-webkit-scrollbar-thumb { background: var(–rust); border-radius: 10px; }

.mini-card {
background: white;
border-radius: 14px;
padding: 14px 16px;
display: flex;
gap: 12px;
cursor: pointer;
transition: all 0.2s;
border: 2px solid transparent;
box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}
.mini-card:hover {
border-color: var(–rust);
transform: translateX(3px);
}
.mini-card-img {
width: 56px;
height: 56px;
border-radius: 10px;
object-fit: cover;
flex-shrink: 0;
background: linear-gradient(135deg, #C4572A, #D4A843);
display: flex;
align-items: center;
justify-content: center;
font-size: 1.5rem;
}
.mini-card-info h4 {
font-size: 0.85rem;
font-weight: 600;
color: var(–navy);
margin-bottom: 3px;
line-height: 1.2;
}
.mini-card-info p {
font-size: 0.72rem;
color: #888;
margin-bottom: 4px;
}
.mini-card-rating {
font-size: 0.7rem;
color: var(–gold);
font-weight: 600;
}

/* PLACES GRID */
.places-section {
padding: 80px 40px;
background: #f0ebe0;
}

.places-grid {
max-width: 1200px;
margin: 0 auto;
display: grid;
grid-template-columns: repeat(3, 1fr);
gap: 24px;
}

.place-card {
background: white;
border-radius: 20px;
overflow: hidden;
transition: all 0.3s;
box-shadow: 0 4px 16px rgba(0,0,0,0.06);
cursor: pointer;
}
.place-card:hover {
transform: translateY(-8px);
box-shadow: 0 20px 50px rgba(26,39,68,0.15);
}

.place-card-img {
height: 200px;
position: relative;
overflow: hidden;
display: flex;
align-items: center;
justify-content: center;
font-size: 4rem;
}
.place-card-img.kremlin { background: linear-gradient(135deg, #1A2744, #2C3E5A); }
.place-card-img.embankment { background: linear-gradient(135deg, #1E4D7B, #2980b9); }
.place-card-img.market { background: linear-gradient(135deg, #8B4513, #C4572A); }
.place-card-img.art { background: linear-gradient(135deg, #4A1942, #8B2F7A); }
.place-card-img.cathedral { background: linear-gradient(135deg, #2D5A27, #4CAF50); }
.place-card-img.theater { background: linear-gradient(135deg, #7B3F00, #D4A843); }

.place-badge {
position: absolute;
top: 14px;
left: 14px;
background: rgba(15,26,46,0.8);
backdrop-filter: blur(6px);
color: var(–gold);
font-size: 0.65rem;
font-weight: 600;
letter-spacing: 0.1em;
text-transform: uppercase;
padding: 4px 10px;
border-radius: 12px;
}

.place-card-body {
padding: 20px 22px 22px;
}
.place-card-body h3 {
font-family: ‘Playfair Display’, serif;
font-size: 1.15rem;
font-weight: 700;
color: var(–navy);
margin-bottom: 6px;
line-height: 1.3;
}
.place-card-body p {
font-size: 0.82rem;
color: #6b6b6b;
line-height: 1.6;
margin-bottom: 14px;
}

.place-meta {
display: flex;
align-items: center;
justify-content: space-between;
font-size: 0.75rem;
}
.place-hours {
color: #4CAF50;
font-weight: 600;
display: flex;
align-items: center;
gap: 4px;
}
.place-hours.closed { color: #e53e3e; }
.place-rating {
display: flex;
align-items: center;
gap: 4px;
color: var(–gold);
font-weight: 700;
}

.place-card-footer {
padding: 0 22px 18px;
display: flex;
gap: 8px;
}
.tag {
background: #f0ebe0;
color: var(–text);
font-size: 0.7rem;
padding: 4px 10px;
border-radius: 12px;
font-weight: 500;
}

/* BIG FEATURED */
.featured-section {
padding: 80px 40px;
background: var(–dark);
position: relative;
overflow: hidden;
}
.featured-section::before {
content: ‘’;
position: absolute;
top: -100px;
right: -100px;
width: 500px;
height: 500px;
background: radial-gradient(circle, rgba(196,87,42,0.08) 0%, transparent 70%);
border-radius: 50%;
}

.featured-inner {
max-width: 1200px;
margin: 0 auto;
}

.featured-grid {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 32px;
margin-top: 48px;
}

.featured-card {
border-radius: 20px;
overflow: hidden;
position: relative;
min-height: 300px;
display: flex;
align-items: flex-end;
cursor: pointer;
transition: transform 0.3s;
}
.featured-card:hover { transform: scale(1.02); }
.featured-card:first-child { grid-row: span 2; min-height: 640px; }

.featured-bg {
position: absolute;
inset: 0;
}
.featured-bg-1 {
background: linear-gradient(135deg, #1A2744 0%, #C4572A 100%);
}
.featured-bg-2 { background: linear-gradient(135deg, #2D5A27, #4a7c3f); }
.featured-bg-3 { background: linear-gradient(135deg, #1E4D7B, #C4572A); }

.featured-overlay {
position: absolute;
inset: 0;
background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, transparent 60%);
}

.featured-emoji {
position: absolute;
top: 50%;
left: 50%;
transform: translate(-50%, -60%);
font-size: 6rem;
opacity: 0.15;
}

.featured-content {
position: relative;
z-index: 2;
padding: 28px;
width: 100%;
}

.featured-cat {
display: inline-block;
font-size: 0.65rem;
letter-spacing: 0.14em;
text-transform: uppercase;
color: var(–gold);
margin-bottom: 8px;
}
.featured-title {
font-family: ‘Playfair Display’, serif;
font-size: 1.4rem;
color: white;
font-weight: 700;
line-height: 1.25;
margin-bottom: 6px;
}
.featured-desc {
font-size: 0.8rem;
color: rgba(255,255,255,0.65);
line-height: 1.5;
margin-bottom: 16px;
}
.featured-link {
color: white;
text-decoration: none;
font-size: 0.78rem;
font-weight: 600;
display: inline-flex;
align-items: center;
gap: 6px;
border-bottom: 1px solid rgba(255,255,255,0.3);
padding-bottom: 2px;
transition: border-color 0.2s;
}
.featured-link:hover { border-color: var(–gold); color: var(–gold); }

/* ROUTES */
.routes-section {
padding: 80px 40px;
background: var(–cream);
}

.routes-grid {
max-width: 1200px;
margin: 0 auto;
display: grid;
grid-template-columns: repeat(4, 1fr);
gap: 20px;
}

.route-card {
background: var(–navy);
border-radius: 18px;
padding: 24px;
cursor: pointer;
transition: all 0.3s;
position: relative;
overflow: hidden;
}
.route-card::before {
content: ‘’;
position: absolute;
bottom: -20px;
right: -20px;
width: 100px;
height: 100px;
background: rgba(255,255,255,0.03);
border-radius: 50%;
}
.route-card:hover { transform: translateY(-6px); background: var(–mid); }

.route-icon { font-size: 2rem; margin-bottom: 14px; display: block; }
.route-card h3 {
font-family: ‘Playfair Display’, serif;
font-size: 1.05rem;
color: var(–cream);
margin-bottom: 8px;
line-height: 1.3;
}
.route-card p {
font-size: 0.78rem;
color: rgba(245,239,230,0.5);
line-height: 1.5;
margin-bottom: 16px;
}
.route-meta {
display: flex;
align-items: center;
gap: 12px;
font-size: 0.72rem;
color: var(–gold);
}
.route-meta span {
display: flex;
align-items: center;
gap: 4px;
}

/* EVENTS */
.events-section {
padding: 80px 40px;
background: #f0ebe0;
}

.events-list {
